package the.chak.pricing;
import the.chak.ecommerce.orders.boundary.dto.OrderDTO;
import the.chak.ecommerce.orders.boundary.dto.ProductVO;

rule "If products qty is above 5 apply 5% reduction"
    when
        $order: OrderDTO()
        $product: ProductVO(qty > 5) from $order.products
    then
        $product.setPrice($product.getPrice() * 0.95);
end