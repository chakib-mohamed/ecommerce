<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Skip Maven wrapper auto-generated files -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="MavenWrapperDownloader\.java$"/>
    </module>

    <module name="SuppressWarningsFilter"/>

    <!-- No trailing whitespace on any line -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="minimum" value="0"/>
        <property name="maximum" value="0"/>
        <property name="message" value="Line has trailing whitespace."/>
    </module>

    <module name="TreeWalker">
        <module name="SuppressWarningsHolder"/>

        <!-- ── Imports ────────────────────────────────────── -->
        <module name="AvoidStarImport">
            <property name="excludes" value="java.lang.annotation"/>
        </module>
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="IllegalImport"/>

        <!-- ── Blocks ─────────────────────────────────────── -->
        <module name="NeedBraces"/>
        <module name="EmptyBlock">
            <!-- Allow empty blocks only when they contain a comment -->
            <property name="option" value="TEXT"/>
        </module>
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignored|ignore"/>
        </module>

        <!-- ── Code quality ───────────────────────────────── -->
        <module name="EqualsAvoidNull"/>
        <module name="StringLiteralEquality"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <module name="OneStatementPerLine"/>

        <!-- ── Whitespace ─────────────────────────────────── -->
        <module name="WhitespaceAfter">
            <property name="tokens" value="COMMA, SEMI, TYPECAST"/>
        </module>
        <module name="NoWhitespaceAfter">
            <property name="tokens" value="BNOT, DEC, DOT, INC, LNOT, UNARY_MINUS, UNARY_PLUS, ARRAY_DECLARATOR"/>
        </module>
        <module name="GenericWhitespace"/>
    </module>
</module>
