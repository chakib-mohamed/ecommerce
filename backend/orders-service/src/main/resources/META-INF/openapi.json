  "components" : {
    "schemas" : {
      "AddItemRequest" : {
        "required" : [ "productId", "quantity" ],
        "type" : "object",
        "properties" : {
          "productId" : {
            "description" : "ID of the product to add",
            "pattern" : "\\S",
            "type" : "string"
          },
          "quantity" : {
            "format" : "int32",
            "description" : "Quantity to add",
            "minimum" : 1,
            "type" : "integer"
          }
        }
      },
      "UpdateItemRequest" : {
        "required" : [ "quantity" ],
        "type" : "object",
        "properties" : {
          "quantity" : {
            "format" : "int32",
            "description" : "New quantity for the item",
            "minimum" : 1,
            "type" : "integer"
          }
        }
      },
      "CartItemResponse" : {
        "type" : "object",
        "properties" : {
          "productId" : {
            "type" : "string"
          },
          "quantity" : {
            "type" : "integer"
          },
          "unitPrice" : {
            "format" : "double",
            "type" : "number"
          },
          "totalPrice" : {
            "format" : "double",
            "type" : "number"
          }
        }
      },
      "CartResponse" : {
        "type" : "object",
        "properties" : {
          "userId" : {
            "type" : "string"
          },
          "items" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/CartItemResponse"
            }
          },
          "updatedAt" : {
            "format" : "date-time",
            "type" : "string"
          }
        }
      },
      "CheckoutResponse" : {
        "type" : "object",
        "properties" : {
          "orderId" : {
            "type" : "string"
          },
          "status" : {
            "type" : "string"
          },
          "price" : {
            "format" : "double",
            "type" : "number"
          },
          "createdAt" : {
            "format" : "date-time",
            "type" : "string"
          }
        }
      },
      "ErrorResponse" : {
        "type" : "object",
        "properties" : {
          "message" : {
            "type" : "string"
          }
        }
      },
      "LocalDateTime" : {
        "format" : "date-time",
        "type" : "string",
        "example" : "2022-03-10T12:15:50"
      },
      "OrderDTO" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "string"
          },
          "cardNumber" : {
            "type" : "string"
          },
          "creationDate" : {
            "$ref" : "#/components/schemas/LocalDateTime"
          },
          "expirationDate" : {
            "type" : "string"
          },
          "price" : {
            "format" : "double",
            "type" : "number"
          },
          "products" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/ProductVO"
            }
          },
          "userID" : {
            "type" : "string"
          },
          "validationNumber" : {
            "type" : "string"
          },
          "status" : {
            "$ref" : "#/components/schemas/OrderStatus"
          }
        }
      },
      "OrderRequest" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "string"
          },
          "products" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/ProductVO"
            }
          }
        }
      },
      "OrderStatus" : {
        "enum" : [ "INITIATED", "CONFIRMED" ],
        "type" : "string"
      },
      "ProductVO" : {
        "type" : "object",
        "properties" : {
          "productID" : {
            "type" : "string"
          },
          "title" : {
            "type" : "string"
          },
          "qty" : {
            "format" : "int32",
            "type" : "integer"
          },
          "price" : {
            "format" : "double",
            "type" : "number"
          },
          "percentageOff" : {
            "format" : "double",
            "type" : "number"
          }
        }
      },
      "SearchOrdersCommand" : {
        "type" : "object",
        "properties" : {
          "userID" : {
            "type" : "string"
          },
          "offset" : {
            "format" : "int32",
            "type" : "integer"
          },
          "limit" : {
            "format" : "int32",
            "type" : "integer"
          },
          "sortBy" : {
            "type" : "string"
          }
        }
      },
      "TupleIntegerListOrderDTO" : {
        "type" : "object",
        "properties" : {
          "x" : {
            "format" : "int32",
            "type" : "integer"
          },
          "y" : {
            "type" : "array",
            "items" : {
              "$ref" : "#/components/schemas/OrderDTO"
            }
          }
        }
      }
    },
    "securitySchemes" : {
      "bearerAuth" : {
        "type" : "http",
        "scheme" : "bearer",
        "bearerFormat" : "JWT"
      },
      "SecurityScheme" : {
        "type" : "http",
        "scheme" : "bearer",
        "bearerFormat" : "JWT",
        "description" : "Authentication"
      }
    }
  },
  "security" : [ {
    "bearerAuth" : [ ]
  } ]
}