#!/usr/bin/env sh
# Pre-push gate: Checkstyle + SpotBugs across all backend modules.
# Skips tests (no Testcontainers), so it is safe to run from the aggregator root.
# Aborts the push on any violation.
# Bypass intentionally (discouraged) with: git push --no-verify
set -e

ROOT="$(git rev-parse --show-toplevel)"

echo "==> pre-push: running Checkstyle + SpotBugs on backend (tests skipped)..."

# Run with backend/ as the Maven execution root so that
# ${session.executionRootDirectory}/checkstyle.xml resolves correctly.
cd "$ROOT/backend"
./mvnw -B -DskipTests -Dmaven.test.skip=true \
  compile checkstyle:check spotbugs:check

echo "==> pre-push: static checks passed."
