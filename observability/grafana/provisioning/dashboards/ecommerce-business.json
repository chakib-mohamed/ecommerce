{
  "uid": "ecommerce-business",
  "title": "Ecommerce Business KPIs",
  "tags": ["ecommerce", "business", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Orders & Revenue",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Orders created (orders/min)",
      "description": "Business throughput of new orders. orders_created_total counts each saved order; shown per minute.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "opm", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(orders_created_total[$__rate_interval])) * 60",
          "legendFormat": "orders/min"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Order value (p50 / p95)",
      "description": "Distribution of order value (order.getPrice()). Percentiles computed from the order_value_amount histogram buckets.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 2, "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(order_value_amount_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(order_value_amount_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Orders confirmed (orders/min)",
      "description": "Rate of order confirmations. orders_confirmed_total counts each confirmed order; shown per minute.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "opm", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(orders_confirmed_total[$__rate_interval])) * 60",
          "legendFormat": "confirmed/min"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cart checkouts by outcome (per min)",
      "description": "Cart checkout attempts split by outcome. Failures are recorded when the cart is missing or empty before the exception propagates.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "opm", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "success" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (outcome) (rate(checkouts_total[$__rate_interval])) * 60",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Authentication",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Logins by outcome (per min)",
      "description": "Login attempts split by outcome. Failure covers unknown-email and bad-password identically (timing-safe path).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": { "unit": "opm", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "success" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
