    {
      "id": 9,
      "type": "timeseries",
      "title": "Image uploads & price updates consumed (per min)",
      "description": "Product image uploads and price-update events consumed from the pricing stream.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "fieldConfig": {
        "defaults": { "unit": "opm", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] } },
